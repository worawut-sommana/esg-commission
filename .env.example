DATABASE_URL=postgresql://user:password@host:5432/dbname

# Used only for local dev (npm run dev) so the API server doesn't collide with
# the frontend dev server's port. Not needed in production — Railway sets
# PORT for you and the server falls back to that automatically.
API_PORT=3001

# Random secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string
